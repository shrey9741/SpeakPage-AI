{
  "manifest_version": 3,
  "name": "SpeakPage AI: Multimodal Web Reader",
  "version": "3.0",
  "description": "On-device AI reading assistant powered by Chrome Built-in AI (Gemini Nano). Summarize, translate, simplify and read any webpage aloud — privately, offline, no server needed.",

  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "SpeakPage AI Reader"
  },

  "background": {
    "service_worker": "service_worker.js"
  },

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "notifications",
    "tts",
    "sidePanel"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ]
}
